# Ignore everything by default
*

# Then whitelist what we want
!.gitignore
!README.md
!CLAUDE.md

# Config directories
!alacritty/
!alacritty/**
!emacs/
!emacs/**
!docs/
!docs/**
!install/
!install/**
!tmux/
!tmux/**
!git/
!git/**
!karabiner/
!karabiner/**
!backlog/
!backlog/**
!hosts/
!hosts/**
!home/
!home/**
!overlays/
!overlays/**

# Nix
!flake.nix
!flake.lock

# Exclude build artifacts even in whitelisted dirs
*.elc
*.eln
eln-cache/
*~
emacs/custom.el
emacs/elgrep-data.el

# Exclude backlog drafts
backlog/drafts/*

# macOS
.DS_Store
