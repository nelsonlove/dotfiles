[general]
accounts = Gmail
maxsyncaccounts = 3
pythonfile = $XDG_CONFIG_HOME/offlineimap/offlineimap.py
sslcacertfile = $SSL_CERT_FILE

[Account Gmail]
localrepository = GmailLocal
remoterepository = GmailRemote
postsynchook = mu index

[Repository GmailLocal]
type = Maildir
localfolders = $XDG_DATA_HOME/offlineimap/L7

[Repository GmailRemote]
type = IMAP
ssl = yes
# sslcacertfile = $SSL_CERT_FILE
sslcacertfile = /usr/local/etc/openssl@3/cert.pem
remotehost = imap.gmail.com
remoteuser = your-email@example.com
remotepasseval = get_password("imap.gmail.com", "your-email@example.com", 993)
folderfilter = lambda foldername: foldername not in ['[Gmail]/Spam', '[Gmail]/All Mail', '[Gmail]/Starred', '[Gmail]/Important', 'Notes', 'Reminders']
holdconnectionopen = true
keepalive = 60
maxconnections = 1
realdelete = no
