hyper -  q               : open kmtrigger://macro=Quick%20Start
hyper -  r               : open kmtrigger://macro=Record%20Screen

# add an on_enter command to the default mode
:: default               : yabai -m config active_window_border_color 0xff775759;\
                           yabai -m config normal_window_border_color 0xff775759
# add a mode for yabai that captures keypresses
:: yabai                 : yabai -m config active_window_border_color 0xff00ff00;\
                           yabai -m config normal_window_border_color 0xff00ff00

# Enter yabai nmode
hyper - w                ; yabai

# Exit yabai mode
yabai < escape           ; default
yabai < hyper - w        : skhd -k "escape"

# yabai mode bindings
yabai < 1                : skhd -k "escape"; yabai -m space --focus desktop1
yabai < 2                : skhd -k "escape"; yabai -m space --focus emacs1
yabai < 3                : skhd -k "escape"; yabai -m space --focus browse1
yabai < 4                : skhd -k "escape"; yabai -m space --focus comm
yabai < 5                : skhd -k "escape"; yabai -m space --focus desktop2
yabai < 6                : skhd -k "escape"; yabai -m space --focus emacs2
yabai < 7                : skhd -k "escape"; yabai -m space --focus browse2
yabai < 8                : skhd -k "escape"; yabai -m space --focus esp

yabai < q                : skhd -k "escape"; yabai -m space --focus desktop1
yabai < w                : skhd -k "escape"; yabai -m space --focus emacs1
yabai < e                : skhd -k "escape"; yabai -m space --focus browse1
yabai < r                : skhd -k "escape"; yabai -m space --focus comm

yabai < a                : skhd -k "escape"; yabai -m space --focus desktop2; yabai -m space --focus desktop1
yabai < s                : skhd -k "escape"; yabai -m space --focus emacs2; yabai -m space --focus emacs1
yabai < d                : skhd -k "escape"; yabai -m space --focus browse2; yabai -m space --focus browse1
yabai < f                : skhd -k "escape"; yabai -m space --focus esp; yabai -m space --focus comm

yabai < z                : skhd -k "escape"; yabai -m space --focus desktop2
yabai < x                : skhd -k "escape"; yabai -m space --focus emacs2
yabai < c                : skhd -k "escape"; yabai -m space --focus browse2
yabai < v                : skhd -k "escape"; yabai -m space --focus esp

yabai < cmd - f          : skhd -k "escape"; yabai -m window --toggle float
yabai < cmd - r          : skhd -k "escape"; brew services restart skhd
yabai < cmd + alt - r    : skhd -k "escape"; brew services restart yabai

yabai < 0x2C             : skhd -k "escape"; yabai -m window --toggle split
# :: spaces
# yabai < hyper - s        ; spaces
yabai < 0x2B             : skhd -k "escape"; yabai -m space --rotate 90
yabai < 0x2F             : skhd -k "escape"; yabai -m space --rotate 270
yabai < left             : skhd -k "escape"; yabai -m space --focus prev
yabai < right            : skhd -k "escape"; yabai -m space --focus next
yabai < shift - left     : skhd -k "escape"; yabai -m space --move prev
yabai < shift - right    : skhd -k "escape"; yabai -m space --move next
yabai < cmd - y          : skhd -k "escape"; yabai -m space --mirror x-axis
yabai < shift - x        : skhd -k "escape"; yabai -m space --mirror y-axis
