#yabai -m rule --add app="^Mail$"     space=comm grid=3:4:0:1:1:1
#yabai -m rule --add app="^Calendar$" space=comm grid=3:4:0:2:1:1
#yabai -m rule --add app="^Emacs$" space=comm grid=3:4:1:0:1:3
# need rule for both
#yabai -m rule --add app="^Google Chrome$" space=comm grid=3:4:2:0:3:2
# title="(?!.*(^(L7 )?ESP:.*))"
# yabai -m rule --add app="^Google Chrome$" title="(?!.*(^(L7 )?ESP:.*))" space=comm grid=3:5:3:0:2:3
# yabai -m rule --add app="^Google Chrome$" title="^(L7 )?ESP:.*" space=8

# displays

