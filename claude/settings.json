{
  "permissions": {
    "defaultMode": "auto"
  },
  "theme": "dark",
  "tui": "fullscreen",
  "autoMemoryDirectory": "~/obsidian/00-09 System/03 LLMs & agents/03.17 Claude Code memories",
  "skipDangerousModePermissionPrompt": true,
  "extraKnownMarketplaces": {
    "claude-code-plugins-mac": {
      "source": {
        "source": "github",
        "repo": "nelsonlove/claude-code-plugins"
      }
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nelson/.claude/hooks/block-edit-shared-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/nelson/.claude/hooks/protect-new-repo.sh",
            "if": "Bash(gh repo create *)",
            "timeout": 15
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ -n \"$TMUX\" ]; then echo \"Running inside tmux session: $(tmux display-message -p '#S')\"; else echo \"Not running inside tmux\"; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "cloudflare@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "github@claude-plugins-official": true,
    "agent-approvals@claude-code-plugins-mac": true,
    "safari@claude-code-plugins-mac": true,
    "vault-skills@claude-code-plugins-mac": true,
    "mail@claude-code-plugins-mac": true,
    "apple-mail@claude-code-plugins-mac": true,
    "vault-mcp-connect@claude-code-plugins-mac": true,
    "claude-tone@claude-code-plugins-mac": false
  }
}
